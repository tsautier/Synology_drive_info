#!/bin/sh

PKG_NAME=$(basename "$SYNOPKG_PKGDEST")
PKG_ROOT="/var/packages/${PKG_NAME}"
TARGET_DIR="/var/packages/$PKG_NAME/target"
UI_DIR="$TARGET_DIR/ui"
MODULES_DIR="$TARGET_DIR/ui/modules"
TEXTS_DIR="$TARGET_DIR/ui/texts"
SETTINGS_DIR="/var/packages/${PKG_NAME}/etc"

# Remove spurious files injected by the package builder
rm -f "$UI_DIR/Makefile"
rm -f "$UI_DIR/ui"         # self-referencing symlink
rm -f "$TEXTS_DIR/strings" # strings file template

# Make scripts and CGI executable
chmod 755 "$UI_DIR/api.cgi"
chmod 755 "$UI_DIR/bin/drive_info.sh"
chmod 755 "$UI_DIR/bin/smart_info.sh"
chmod 755 "$UI_DIR/bin/check_ip_port.sh"
chmod 755 "$UI_DIR/bin/syno_discover.py"
chmod 755 "$UI_DIR/bin/task_scheduler.sh"
chmod 755 "$UI_DIR/modules/get_text.sh"

chmod 644 "$UI_DIR/bin/smr_drive_list.txt"

# For users who have already completed the one-time sudoers setup (see
# set_package_permissions.md), refresh /etc/sudoers.d/drive_info on every
# upgrade so newly added entries take effect immediately, instead of
# waiting for the user to open the UI first. Calls the exact no-argument
# command form that setup already grants.
sudo "$UI_DIR/bin/drive_info.sh"

# Create settings.conf with world-readable/writable permissions
# DSM 7: in var/ (writable by drive_info via run-as:package)
# DSM 6: in etc/ (writable by system CGI user via 666 permissions)
if [[ -d "${PKG_ROOT}/var" ]]; then
    SETTINGS_CONF="${PKG_ROOT}/var/settings.conf"
else
    SETTINGS_CONF="${PKG_ROOT}/etc/settings.conf"
    touch "${SETTINGS_CONF}"
    chmod 666 "${SETTINGS_CONF}"
fi

exit 0
